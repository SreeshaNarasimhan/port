{
  "version": 2,
  "builds": [
    {
      "src": "api/render.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["dist/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/api/render?file=/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/render"
    }
  ]
}
